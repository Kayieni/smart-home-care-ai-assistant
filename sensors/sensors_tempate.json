{
  "system": "elderly_care_digital_twin",
  "version": "1.0",
  "sensors": [
    {
      "activity_id": "hygiene_toilet_wash_hands",
      "name": "Wash hands after toilet",
      "category": "hygiene",
      "risk_level": "A",
      "description": "Detect whether user washes hands after using toilet",
      "sensors_used": [
        {
          "sensor_id": "BATH_WATER_FLOW_01",
          "type": "water_flow",
          "location": "bathroom_sink",
          "purpose": "Detect running water after toilet use"
        },
        {
          "sensor_id": "TOILET_OCCUPANCY_01",
          "type": "contact/occupancy",
          "location": "toilet",
          "purpose": "Detect toilet usage event"
        },
        {
          "sensor_id": "SOAP_VIBRATION_01",
          "type": "vibration",
          "location": "soap_dispenser",
          "purpose": "Detect soap usage"
        }
      ]
    },

    {
      "activity_id": "kitchen_stove_monitoring",
      "name": "Monitor stove/oven left on",
      "category": "safety",
      "risk_level": "A",
      "description": "Detect forgotten stove or oven ON",
      "sensors_used": [
        {
          "sensor_id": "STOVE_POWER_01",
          "type": "smart_plug",
          "location": "kitchen_stove",
          "purpose": "Detect stove power state"
        },
        {
          "sensor_id": "OVEN_TEMP_01",
          "type": "temperature",
          "location": "oven",
          "purpose": "Detect abnormal heat persistence"
        }
      ]
    },

    {
      "activity_id": "door_exit_monitoring",
      "name": "Front door exit detection",
      "category": "safety",
      "risk_level": "A",
      "description": "Detect exits especially unusual times (e.g. 03:00)",
      "sensors_used": [
        {
          "sensor_id": "DOOR_CONTACT_01",
          "type": "contact",
          "location": "front_door",
          "purpose": "Detect door open/close events"
        },
        {
          "sensor_id": "HALLWAY_PIR_01",
          "type": "motion",
          "location": "hallway",
          "purpose": "Confirm movement towards exit"
        }
      ]
    },

    {
      "activity_id": "bed_exit_detection",
      "name": "Getting out of bed",
      "category": "movement",
      "risk_level": "A",
      "description": "Detect waking up and leaving bed",
      "sensors_used": [
        {
          "sensor_id": "BED_PRESSURE_01",
          "type": "pressure",
          "location": "bed",
          "purpose": "Detect presence/absence in bed"
        },
        {
          "sensor_id": "BEDROOM_PIR_01",
          "type": "motion",
          "location": "bedroom",
          "purpose": "Confirm movement after leaving bed"
        }
      ]
    },

    {
      "activity_id": "medication_taken",
      "name": "Medication intake",
      "category": "health",
      "risk_level": "A",
      "description": "Detect if medication was taken",
      "sensors_used": [
        {
          "sensor_id": "MED_BOX_VIBRATION_01",
          "type": "vibration",
          "location": "medicine_box",
          "purpose": "Detect opening/handling medication box"
        }
      ]
    },

    {
      "activity_id": "water_heater_monitoring",
      "name": "Water heater left ON",
      "category": "safety",
      "risk_level": "B",
      "description": "Detect forgotten water heater usage",
      "sensors_used": [
        {
          "sensor_id": "WATER_HEATER_PLUG_01",
          "type": "smart_plug",
          "location": "bathroom",
          "purpose": "Monitor heater power state"
        }
      ]
    },

    {
      "activity_id": "fridge_usage_monitoring",
      "name": "Fridge usage monitoring",
      "category": "activity",
      "risk_level": "B",
      "description": "Detect eating behaviour and fridge misuse",
      "sensors_used": [
        {
          "sensor_id": "FRIDGE_CONTACT_01",
          "type": "contact",
          "location": "kitchen",
          "purpose": "Detect fridge open/close"
        },
        {
          "sensor_id": "KITCHEN_PIR_01",
          "type": "motion",
          "location": "kitchen",
          "purpose": "Detect presence during eating"
        }
      ]
    },

    {
      "activity_id": "balcony_watering_plants",
      "name": "Watering plants",
      "category": "activity",
      "risk_level": "C",
      "description": "Detect plant watering activity",
      "sensors_used": [
        {
          "sensor_id": "BALCONY_PIR_01",
          "type": "motion",
          "location": "balcony",
          "purpose": "Detect presence in balcony"
        },
        {
          "sensor_id": "SOIL_MOISTURE_01",
          "type": "soil_moisture",
          "location": "plant_pot",
          "purpose": "Detect watering activity via soil change"
        }
      ]
    }
  ]
}