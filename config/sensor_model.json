{
  "project": "invisible_caregiver",
  "version": "1.2",

  "value_format_legend": {
    "boolean": "1 = active state, 0 = inactive state",
    "integer": "numeric reading in the specified unit"
  },

  "sensors": [

    {
      "sensor_id": "BED_PRESSURE_01",
      "type": "pressure",
      "location": "bedroom_bed",
      "activity": "sleep_wake",
      "risk_category": "movement",
      "value_format": "boolean",
      "value_map": { "1": "occupied", "0": "empty" }
    },
    {
      "sensor_id": "BEDROOM_PIR_01",
      "type": "motion",
      "location": "bedroom",
      "activity": "movement",
      "risk_category": "movement",
      "value_format": "boolean",
      "value_map": { "1": "motion", "0": "no_motion" }
    },

    {
      "sensor_id": "BATH_WATER_01",
      "type": "water_flow",
      "location": "bathroom_sink",
      "activity": "hand_washing",
      "risk_category": "hygiene",
      "value_format": "boolean",
      "value_map": { "1": "flow", "0": "no_flow" }
    },
    {
      "sensor_id": "SOAP_VIB_01",
      "type": "vibration",
      "location": "soap_dispenser",
      "activity": "hand_washing",
      "risk_category": "hygiene",
      "value_format": "boolean",
      "value_map": { "1": "used", "0": "not_used" }
    },
    {
      "sensor_id": "TOILET_OCCUPANCY_01",
      "type": "occupancy",
      "location": "bathroom_toilet",
      "activity": "toilet_use",
      "risk_category": "hygiene",
      "value_format": "boolean",
      "value_map": { "1": "occupied", "0": "empty" }
    },

    {
      "sensor_id": "FRIDGE_DOOR_01",
      "type": "contact",
      "location": "kitchen_fridge",
      "activity": "eating",
      "risk_category": "activity",
      "value_format": "boolean",
      "value_map": { "1": "open", "0": "closed" }
    },
    {
      "sensor_id": "KITCHEN_PIR_01",
      "type": "motion",
      "location": "kitchen",
      "activity": "movement",
      "risk_category": "activity",
      "value_format": "boolean",
      "value_map": { "1": "motion", "0": "no_motion" }
    },
    {
      "sensor_id": "STOVE_POWER_01",
      "type": "smart_plug",
      "location": "kitchen_stove",
      "activity": "cooking",
      "risk_category": "safety",
      "value_format": "boolean",
      "value_map": { "1": "on", "0": "off" }
    },
    {
      "sensor_id": "OVEN_TEMP_01",
      "type": "temperature",
      "location": "kitchen_oven",
      "activity": "cooking",
      "risk_category": "safety",
      "value_format": "integer",
      "unit": "°C"
    },

    {
      "sensor_id": "MED_BOX_01",
      "type": "vibration",
      "location": "medicine_box",
      "activity": "medication",
      "risk_category": "health",
      "value_format": "boolean",
      "value_map": { "1": "used", "0": "not_used" }
    },

    {
      "sensor_id": "DOOR_CONTACT_01",
      "type": "contact",
      "location": "front_door",
      "activity": "exit_home",
      "risk_category": "safety",
      "value_format": "boolean",
      "value_map": { "1": "open", "0": "closed" }
    },
    {
      "sensor_id": "HALLWAY_PIR_01",
      "type": "motion",
      "location": "hallway",
      "activity": "movement",
      "risk_category": "movement",
      "value_format": "boolean",
      "value_map": { "1": "motion", "0": "no_motion" }
    },

    {
      "sensor_id": "WATER_HEATER_01",
      "type": "smart_plug",
      "location": "bathroom_heater",
      "activity": "utility_usage",
      "risk_category": "safety",
      "value_format": "boolean",
      "value_map": { "1": "on", "0": "off" }
    },

    {
      "sensor_id": "BALCONY_PIR_01",
      "type": "motion",
      "location": "balcony",
      "activity": "leisure",
      "risk_category": "activity",
      "value_format": "boolean",
      "value_map": { "1": "motion", "0": "no_motion" }
    },
    {
      "sensor_id": "SOIL_MOISTURE_01",
      "type": "soil_moisture",
      "location": "balcony_plants",
      "activity": "plant_watering",
      "risk_category": "activity",
      "value_format": "integer",
      "unit": "%"
    }

  ]
}
